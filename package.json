{
  "name": "wayrune",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "infra:up": "./infrastructure/native-up.sh",
    "setup": "pnpm infra:up && pnpm db:generate && pnpm db:check-migrations && pnpm db:migrate:deploy && pnpm db:seed",
    "dev": "APP_ENV=local turbo run dev --parallel --log-prefix=none",
    "dev:local": "APP_ENV=local turbo run dev --parallel --log-prefix=none",
    "dev:dev": "APP_ENV=dev turbo run dev --parallel --log-prefix=none",
    "build": "APP_ENV=${APP_ENV:-prod} turbo run build",
    "build:dev": "APP_ENV=dev turbo run build",
    "build:prod": "APP_ENV=prod turbo run build",
    "start:api": "APP_ENV=${APP_ENV:-prod} pnpm --filter @wayrune/api start",
    "start:worker": "APP_ENV=${APP_ENV:-prod} pnpm --filter @wayrune/worker start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "APP_ENV=local turbo run test",
    "test:integration": "APP_ENV=local turbo run test:integration",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:check-migrations": "node scripts/check-mysql-migrations.mjs",
    "db:migrate": "node scripts/db-migrate-deploy.mjs",
    "db:migrate:deploy": "node scripts/db-migrate-deploy.mjs",
    "db:migrate:create": "node scripts/create-prisma-migration.mjs",
    "db:migrate:repair": "node scripts/repair-migration-checksums.mjs",
    "db:migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed": "node --import tsx prisma/seed/seed.ts",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "presence:catalog:backup": "node --import tsx scripts/presence-catalog/cli.ts backup",
    "presence:catalog:reset": "node --import tsx scripts/presence-catalog/cli.ts reset",
    "presence:catalog:seed": "node --import tsx scripts/presence-catalog/cli.ts seed",
    "presence:catalog:validate": "node --import tsx scripts/presence-catalog/cli.ts validate",
    "presence:catalog:smoke": "node --import tsx scripts/presence-catalog/cli.ts smoke",
    "wr:catalog:backup": "node --import tsx scripts/presence-catalog/cli.ts backup",
    "wr:catalog:reset": "node --import tsx scripts/presence-catalog/cli.ts reset",
    "wr:catalog:seed": "node --import tsx scripts/presence-catalog/cli.ts seed",
    "wr:catalog:validate": "node --import tsx scripts/presence-catalog/cli.ts validate",
    "wr:catalog:smoke": "node --import tsx scripts/presence-catalog/cli.ts smoke"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@wayrune/config": "workspace:*",
    "bcryptjs": "^2.4.3"
  }
}
