    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/testing": "^10.4.15",
    "@prisma/client": "^6.1.0",
    "@travel/auth": "workspace:*",
    "@travel/config": "workspace:*",
    "@travel/contracts": "workspace:*",
    "@travel/observability": "workspace:*",
    "@travel/rbac": "workspace:*",
