  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  place        Place?       @relation(fields: [placeId], references: [id], onDelete: SetNull)
  supersedes   SupplierActivityRate?  @relation("ActivityRateVersionChain", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy SupplierActivityRate[] @relation("ActivityRateVersionChain")

  @@index([organizationId, activityKey, isActive], map: "sar_org_key_active_idx")
  @@index([organizationId, supplierId, isActive], map: "sar_org_supplier_active_idx")
  @@index([organizationId, placeId, isActive], map: "sar_org_place_active_idx")
  @@index([organizationId, isActive], map: "sar_org_active_idx")
  @@index([supersedesId])
  @@map("supplier_activity_rates")
}

/** Stage B — agency invites a local supplier to claim a partner organization link. */
model SupplierInvite {
  id                     String    @id @default(cuid())
  invitingOrganizationId String    @map("inviting_organization_id")
  supplierId             String    @map("supplier_id")
  email                  String?
  tokenHash              String    @unique @map("token_hash")
  suggestedKind          String?   @map("suggested_kind") // hotel | dmc | …
