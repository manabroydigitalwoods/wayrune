model BookingComponent {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  tripId         String    @map("trip_id")
  supplierId     String?   @map("supplier_id")
  /** Partner asset that fulfilled / confirmed this booking (Stage B). */
  partnerAssetId String?   @map("partner_asset_id")
  /**
   * Legacy single SR link (deprecated). Prefer ServiceRequestItem.
   * No longer unique — many SRs can negotiate for one requirement.
   */
  serviceRequestId String? @map("service_request_id")
  type           String    // hotel | transfer | activity | flight_ref | meal | other
  title          String
  /**
   * Agency delivery readiness (BookingRequirement status).
   * pending | required | drafted | requested | acknowledged | held | confirmed | rejected | expired | cancelled
   */
  status         String    @default("pending")
  /** Quote line id when this booking was materialized from an accepted quotation. */
  quotationLineId String?  @map("quotation_line_id")
  confirmationRef String?  @map("confirmation_ref")
  voucherNote    String?   @map("voucher_note") @db.Text
  startAt        DateTime? @map("start_at")
  endAt          DateTime? @map("end_at")
  costAmount     Decimal?  @map("cost_amount") @db.Decimal(14, 2)
  quotedAmount   Decimal?  @map("quoted_amount") @db.Decimal(14, 2)
  confirmedAmount Decimal? @map("confirmed_amount") @db.Decimal(14, 2)
  currency       String    @default("INR") @db.Char(3)
  /** BookingRequirement: required quantity / pax / dietary etc. */
  requiredQuantity       Decimal? @map("required_quantity") @db.Decimal(14, 2)
  travellerRequirementsJson Json? @map("traveller_requirements_json")
  itineraryItemIdsJson   Json?    @map("itinerary_item_ids_json")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  trip         Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  supplier     Supplier?     @relation(fields: [supplierId], references: [id])
  partnerAsset PartnerAsset? @relation(fields: [partnerAssetId], references: [id], onDelete: SetNull)
  serviceRequest    ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  serviceRequestItems ServiceRequestItem[]
  invoices          SupplierInvoice[]
  payments          TripPayment[]
  allocations       InventoryAllocation[]
  stayReservations  StayReservation[]
  driverJobs        DriverJob[]

  @@unique([tripId, quotationLineId])
  @@index([tripId, status])
  @@index([organizationId])
  @@index([partnerAssetId])
  @@index([serviceRequestId])
  @@index([quotationLineId])
  @@map("booking_components")
}

model SupplierInvoice {
  id                 String    @id @default(cuid())
  organizationId     String    @map("organization_id")
  tripId             String    @map("trip_id")
  supplierId         String    @map("supplier_id")
  bookingComponentId String?   @map("booking_component_id")
  invoiceNumber      String    @map("invoice_number")
  amount             Decimal   @db.Decimal(14, 2)
  currency           String    @default("INR") @db.Char(3)
  dueAt              DateTime? @map("due_at")
  status             String    @default("open") // open | partial | paid | cancelled
  notes              String?   @db.Text
  createdBy          String?   @map("created_by")
  updatedBy          String?   @map("updated_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization     Organization      @relation(fields: [organizationId], references: [id])
  trip             Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  supplier         Supplier          @relation(fields: [supplierId], references: [id])
  bookingComponent BookingComponent? @relation(fields: [bookingComponentId], references: [id])
  payments         TripPayment[]

  @@index([tripId, status])
  @@index([organizationId, supplierId])
  @@map("supplier_invoices")
}

model TripPayment {
  id                 String    @id @default(cuid())
  organizationId     String    @map("organization_id")
  tripId             String    @map("trip_id")
  direction          String    // customer | supplier
  label              String
  amount             Decimal   @db.Decimal(14, 2)
  amountPaid         Decimal   @default(0) @map("amount_paid") @db.Decimal(14, 2)
  currency           String    @default("INR") @db.Char(3)
  method             String?   // cash | upi | bank_transfer | card | cheque | other
  reference          String?
  dueAt              DateTime? @map("due_at")
  paidAt             DateTime? @map("paid_at")
  status             String    @default("scheduled") // scheduled | partial | paid | overdue | cancelled
  notes              String?   @db.Text
  supplierInvoiceId  String?   @map("supplier_invoice_id")
  bookingComponentId String?   @map("booking_component_id")
  /** Opaque token for public customer payment-link checkout. */
  paymentLinkToken     String?   @unique @map("payment_link_token")
  paymentLinkExpiresAt DateTime? @map("payment_link_expires_at")
  /** Razorpay order bound at pay-intent (confirm must match). */
  paymentLinkRazorpayOrderId     String? @map("payment_link_razorpay_order_id")
  paymentLinkRazorpayAmountPaise Int?    @map("payment_link_razorpay_amount_paise")
  createdBy          String?   @map("created_by")
  updatedBy          String?   @map("updated_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  trip             Trip              @relation(fields: [tripId], references: [id], onDelete: Cascade)
  supplierInvoice  SupplierInvoice?  @relation(fields: [supplierInvoiceId], references: [id])
  bookingComponent BookingComponent? @relation(fields: [bookingComponentId], references: [id])

  @@index([tripId, direction, status])
  @@index([organizationId])
  @@index([paymentLinkRazorpayOrderId])
  @@map("trip_payments")
}

model TripFeedback {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  score     Int
  note      String?  @db.Text
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
  @@map("trip_feedback")
}

model TripReadinessItem {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  label     String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

