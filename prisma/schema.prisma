// ——— QR Guest Services (Phase 1) ———

/** Place a guest can scan (table, room, zone). Token in QR is opaque publicToken. */
model ServiceLocation {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  assetId        String    @map("asset_id")
  /** RESTAURANT_TABLE | HOTEL_ROOM | HOMESTAY_ROOM | FARMSTAY_UNIT | DINING_ZONE | EVENT_AREA */
  locationType   String    @map("location_type")
  /** Optional link to AssetRoomUnit.id or free-form external key */
  locationRef    String?   @map("location_ref")
  label          String
  publicToken    String    @unique @map("public_token")
  /** active | disabled */
  status         String    @default("active")
  lastScannedAt  DateTime? @map("last_scanned_at")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset        PartnerAsset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tableSessions TableSession[]
  serviceOrders ServiceOrder[]
  guestServiceRequests GuestServiceRequest[]
  guestQrFeedbacks GuestQrFeedback[]

  @@index([organizationId, assetId])
  @@index([assetId, status])
  @@map("service_locations")
}

/** A la carte / room-service catalogue item (not MealPackage). */
model ServiceOffering {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  assetId        String    @map("asset_id")
  name           String
  description    String?   @db.Text
  category       String    @default("other")
  /** food | beverage | laundry | housekeeping | transport | maintenance | other */
  kind           String    @default("food")
  unitPrice      Decimal   @map("unit_price") @db.Decimal(14, 2)
  taxPercent     Decimal   @default(0) @map("tax_percent") @db.Decimal(5, 2)
  currency       String    @default("INR") @db.Char(3)
  dietaryLabels  Json?     @map("dietary_labels")
  imageUrl       String?   @map("image_url")
  sortOrder      Int       @default(0) @map("sort_order")
  isActive       Boolean   @default(true) @map("is_active")
  stopSell       Boolean   @default(false) @map("stop_sell")
  maxQuantity    Int?      @map("max_quantity")
  /** Minutes; advisory for guest UI */
  prepMinutes    Int?      @map("prep_minutes")
  /** Optional HH:mm window when available (null = always during accepting-hours) */
  availableFrom  String?   @map("available_from") @db.VarChar(5)
  availableUntil String?   @map("available_until") @db.VarChar(5)
  /** [{ id, name, minSelect, maxSelect, options: [{ id, name, priceDelta }] }] */
  modifiersJson  Json?     @map("modifiers_json")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset        PartnerAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  orderItems   ServiceOrderItem[]
  ratings      ServiceOfferingRating[]

  @@index([organizationId, assetId, isActive])
  @@index([assetId, category])
  @@map("service_offerings")
}

/** Guest-submitted star rating for a catalogue dish (real aggregates only). */
model ServiceOfferingRating {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  assetId        String   @map("asset_id")
  offeringId     String   @map("offering_id")
  serviceOrderId String?  @map("service_order_id")
  stars          Int
  comment        String?  @db.Text
  fingerprint    String?  @db.VarChar(64)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset        PartnerAsset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  offering     ServiceOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  @@unique([offeringId, serviceOrderId])
  @@index([assetId, offeringId])
  @@index([organizationId, createdAt])
  @@map("service_offering_ratings")
}

/** Post-meal / post-stay QR companion feedback. */
model GuestQrFeedback {
  id                String   @id @default(cuid())
  organizationId    String   @map("organization_id")
  assetId           String   @map("asset_id")
  serviceLocationId String   @map("service_location_id")
  tableSessionId    String?  @map("table_session_id")
  stayReservationId String?  @map("stay_reservation_id")
  /** 0–10 NPS */
  nps               Int
  /** 1–5 overall stars */
  stars             Int?
  tagsJson          Json?    @map("tags_json")
  comment           String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset           PartnerAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  serviceLocation ServiceLocation @relation(fields: [serviceLocationId], references: [id], onDelete: Cascade)

  @@index([assetId, createdAt])
  @@index([organizationId, createdAt])
  @@map("guest_qr_feedbacks")
}

/** Open dining cover for a restaurant table QR. */
model TableSession {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  assetId        String    @map("asset_id")
  serviceLocationId String @map("service_location_id")
  guestCount     Int       @default(1) @map("guest_count")
  /** open | bill_requested | billed | paid | closed */
  status         String    @default("open")
  amountPaid     Decimal   @default(0) @map("amount_paid") @db.Decimal(14, 2)
  currency       String    @default("INR") @db.Char(3)
  openedBy       String?   @map("opened_by")
  openedAt       DateTime  @default(now()) @map("opened_at")
  closedAt       DateTime? @map("closed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset           PartnerAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  serviceLocation ServiceLocation @relation(fields: [serviceLocationId], references: [id], onDelete: Cascade)
  serviceOrders   ServiceOrder[]
  folioCharges    FolioCharge[]

  @@index([assetId, status])
  @@index([serviceLocationId, status])
  @@map("table_sessions")
}

model ServiceOrder {
  id                String    @id @default(cuid())
  organizationId    String    @map("organization_id")
  assetId           String    @map("asset_id")
  serviceLocationId String    @map("service_location_id")
  tableSessionId    String?   @map("table_session_id")
  stayReservationId String?   @map("stay_reservation_id")
  /** QR | STAFF | PHONE | GUEST_PORTAL */
  sourceType        String    @default("QR") @map("source_type")
  /** draft | placed | accepted | preparing | ready | out_for_delivery | served | completed | rejected | cancelled */
  status            String    @default("placed")
  currency          String    @default("INR") @db.Char(3)
  subtotal          Decimal   @db.Decimal(14, 2)
  taxTotal          Decimal   @default(0) @map("tax_total") @db.Decimal(14, 2)
  total             Decimal   @db.Decimal(14, 2)
  customerNote      String?   @map("customer_note") @db.Text
  idempotencyKey    String?   @map("idempotency_key")
  folioPostedAt     DateTime? @map("folio_posted_at")
  placedAt          DateTime  @default(now()) @map("placed_at")
  acceptedAt        DateTime? @map("accepted_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset           PartnerAsset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  serviceLocation ServiceLocation  @relation(fields: [serviceLocationId], references: [id], onDelete: Cascade)
  tableSession    TableSession?     @relation(fields: [tableSessionId], references: [id], onDelete: SetNull)
  stayReservation StayReservation? @relation(fields: [stayReservationId], references: [id], onDelete: SetNull)
  items           ServiceOrderItem[]

  @@unique([organizationId, idempotencyKey])
  @@index([assetId, status])
  @@index([serviceLocationId, placedAt])
  @@index([tableSessionId])
  @@index([stayReservationId])
  @@map("service_orders")
}

model ServiceOrderItem {
  id              String  @id @default(cuid())
  orderId         String  @map("order_id")
  offeringId      String? @map("offering_id")
  nameSnapshot    String  @map("name_snapshot")
  quantity        Int     @default(1)
  unitPriceSnapshot Decimal @map("unit_price_snapshot") @db.Decimal(14, 2)
  taxSnapshot     Decimal @default(0) @map("tax_snapshot") @db.Decimal(14, 2)
  lineTotal       Decimal @map("line_total") @db.Decimal(14, 2)
  instructions    String? @db.Text
  /** Snapshotted modifier picks [{ groupId, optionId, name, priceDelta }] */
  modifiersSnapshotJson Json? @map("modifiers_snapshot_json")
  /** placed | accepted | preparing | ready | served | cancelled */
  status          String  @default("placed")

  order    ServiceOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  offering ServiceOffering? @relation(fields: [offeringId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("service_order_items")
}

/** Non-food guest request from QR UI (towels, maintenance…). */
model GuestServiceRequest {
  id                String    @id @default(cuid())
  organizationId    String    @map("organization_id")
  assetId           String    @map("asset_id")
  serviceLocationId String    @map("service_location_id")
  stayReservationId String?   @map("stay_reservation_id")
  /** housekeeping | laundry | maintenance | front_desk | transport | other */
  category          String    @default("housekeeping")
  title             String
  notes             String?   @db.Text
  /** requested | accepted | in_progress | done | cancelled */
  status            String    @default("requested")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  completedAt       DateTime? @map("completed_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset           PartnerAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  serviceLocation ServiceLocation @relation(fields: [serviceLocationId], references: [id], onDelete: Cascade)

