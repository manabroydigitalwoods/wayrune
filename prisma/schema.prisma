  rateAmount           Decimal?  @map("rate_amount") @db.Decimal(14, 2)
  currency             String    @default("INR") @db.Char(3)
  notes                String?   @db.Text
  /** Booker-level waiver acknowledgement (A-XP-04). */
  waiverAckAt          DateTime? @map("waiver_ack_at")
  waiverTextSnapshot   String?   @map("waiver_text_snapshot") @db.Text
  createdBy            String?   @map("created_by")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  asset             PartnerAsset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  experienceProduct ExperienceProduct       @relation(fields: [experienceProductId], references: [id], onDelete: Cascade)
  experienceSlot    ExperienceSlot          @relation(fields: [experienceSlotId], references: [id], onDelete: Cascade)
  inventoryHold     InventoryHold?          @relation(fields: [inventoryHoldId], references: [id], onDelete: SetNull)
  party             Party?                  @relation(fields: [partyId], references: [id], onDelete: SetNull)
  participants      ExperienceParticipant[]

  @@index([assetId, status])
  @@index([experienceSlotId])
  @@index([partyId])
  @@map("experience_reservations")
}

model ExperienceParticipant {
