generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Identity & tenancy ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships      OrganizationMembership[]
  refreshTokens    RefreshToken[]
  assignedLeads    Lead[]                   @relation("LeadOwner")
  assignedTasks    Task[]                   @relation("TaskAssignee")
  notifications    Notification[]
  auditEvents      AuditEvent[]             @relation("AuditActor")
  presenceCatalogReviews PresenceCatalogReview[]

  @@map("users")
}

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  /** Human-friendly public id (invoices, widget, ingest URLs). Starts at 10001. */
  publicCode     Int      @unique @map("public_code")
  /** Host label → {subdomain}.{SITE_BASE_DOMAIN} */
  subdomain      String?  @unique
  /** Optional custom apex/www domain (verification/TLS later). */
  customDomain   String?  @unique @map("custom_domain")
  kind           String   @default("travel_agency") // travel_agency | platform | hotel | homestay | farmstay | car_rental | driver | restaurant | dmc | other
  timezone       String   @default("Asia/Kolkata")
  currency       String   @default("INR") @db.Char(3)
  taxLabel       String   @default("GST") @map("tax_label")
  brandingJson   Json?    @map("branding_json")
  settingsJson   Json?    @map("settings_json")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  memberships     OrganizationMembership[]
  roles           Role[]
  parties         Party[]
  pipelines       Pipeline[]
  leads           Lead[]
  leadSources     LeadSource[]
  campaigns       Campaign[]
  inquiries       Inquiry[]
  trips           Trip[]
  tasks           Task[]
  documents       Document[]
  notifications   Notification[]
  auditEvents     AuditEvent[]
  outboxEvents    OutboxEvent[]
  itineraryBlocks ItineraryBlock[]
  quoteTemplates  QuoteTemplate[]
  places          Place[]
  placeCategories PlaceCategory[]
  placeSubcategories PlaceSubcategory[]
  roomTypes       RoomType[]
  vehicleTypes    VehicleType[]
  suppliers       Supplier[]
  supplierHotelRates SupplierHotelRate[]
  supplierActivityRates SupplierActivityRate[]
  transferFares   TransferFare[]
  supplierInvoices SupplierInvoice[]
  partnerProfile  OrganizationPartnerProfile?
  relationshipsFrom OrgRelationship[] @relation("OrgRelationshipFrom")
  relationshipsTo   OrgRelationship[] @relation("OrgRelationshipTo")
  linkedAsSupplier  Supplier[] @relation("SupplierLinkedOrg")
  partnerAssets     PartnerAsset[]
  supplierInvitesSent    SupplierInvite[] @relation("SupplierInviteFrom")
  supplierInvitesClaimed SupplierInvite[] @relation("SupplierInviteClaimed")
  serviceLocations       ServiceLocation[]
  serviceOfferings       ServiceOffering[]
  tableSessions          TableSession[]
  serviceOrders          ServiceOrder[]
  guestServiceRequests   GuestServiceRequest[]
  serviceOfferingRatings ServiceOfferingRating[]
  guestQrFeedbacks       GuestQrFeedback[]
  policies               Policy[]
  serviceRequestsBought  ServiceRequest[] @relation("ServiceRequestBuyer")
  serviceRequestsSold    ServiceRequest[] @relation("ServiceRequestSeller")
  commercialDocuments    CommercialDocument[]
  paymentRecords         PaymentRecord[]
  conversations          Conversation[]
  businessTimelineEvents BusinessTimelineEvent[]
  supplierContracts      SupplierContract[]
  tripChangeCases        TripChangeCase[]
  serviceIncidents       ServiceIncident[]
  negotiatedRatesAsBuyer NegotiatedRate[] @relation("NegotiatedRateBuyer")
  partnerSettlements     PartnerSettlement[]
  partnerRatingsGiven    PartnerRating[] @relation("PartnerRatingFrom")
  partnerRatingsReceived PartnerRating[] @relation("PartnerRatingTo")
  inventoryHolds         InventoryHold[]
  cancellationCases      CancellationCase[]
  dataQualityIssues      DataQualityIssue[]
  workflowRecoveryItems  WorkflowRecoveryItem[]
  interactions           Interaction[]
  engagementConversations EngagementConversation[]
  whatsappTemplates      WhatsAppTemplate[]
  customFieldDefinitions CustomFieldDefinition[]
  engagementAutomationRules EngagementAutomationRule[]
  googleConnections      GoogleConnection[]
  presenceSites          PresenceSite[]
  presenceFormDefinitions PresenceFormDefinition[]
  presenceChatWidgets    PresenceChatWidget[]
  presenceThemes         PresenceTheme[]
  presenceModuleDefinitions PresenceModuleDefinition[]
  presenceAssetVersions  PresenceAssetVersion[]
  presenceMarketplaceListings PresenceMarketplaceListing[]
  presenceSiteTemplates  PresenceSiteTemplate[]
  presencePageTemplates  PresencePageTemplate[]
  presenceAnalyticsEvents PresenceAnalyticsEvent[]
  presenceCatalogReviews PresenceCatalogReview[]

  @@index([kind])
  @@map("organizations")
}

model OrganizationPartnerProfile {
  id               String   @id @default(cuid())
  organizationId   String   @unique @map("organization_id")
  discoverable     Boolean  @default(false)
  city             String?
  region           String?
  country          String?  @default("India")
  bio              String?  @db.Text
  serviceTagsJson  Json?    @map("service_tags_json") // string[]
  contactEmail     String?  @map("contact_email")
  contactPhone     String?  @map("contact_phone")
  capacityHint     String?  @map("capacity_hint")
  /** Typed commerce profile (legalName, hours, tax/bank, amenities, geo…). */
  profileJson      Json?    @map("profile_json")
  legalName        String?  @map("legal_name")
  displayName      String?  @map("display_name")
  logoUrl          String?  @map("logo_url")
  website          String?
  latitude         Decimal? @db.Decimal(10, 7)
  longitude        Decimal? @db.Decimal(10, 7)
  /** unverified | pending | verified | rejected */
  verificationStatus String @default("unverified") @map("verification_status")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([discoverable, city])
  @@map("organization_partner_profiles")
}

/**
 * Operable unit under a partner Organization account (multi-property / fleet).
 * Stage D inventory (rooms, fleet slots, driver calendars) hangs off this row.
 */
model PartnerAsset {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  /** hotel | homestay | farmstay | vehicle | driver | restaurant | other */
  assetKind      String    @map("asset_kind")
  name           String
  placeId        String?   @map("place_id")
  /** { imageUrl, imageUrls, amenities, seats, vehicleTypeKey, capacityHint… } */
  profileJson    Json?     @map("profile_json")
  isActive       Boolean   @default(true) @map("is_active")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  place        Place?       @relation("PartnerAssetPlace", fields: [placeId], references: [id], onDelete: SetNull)
  linkedSuppliers Supplier[] @relation("SupplierLinkedAsset")
  bookingComponents BookingComponent[]
  roomProducts      AssetRoomProduct[]
  fleetUnits        AssetFleetUnit[]
  calendarBlocks    AssetCalendarBlock[]
  serviceOffers     AssetServiceOffer[]
  allocations       InventoryAllocation[]
  stayReservations  StayReservation[]
  buildings         AssetBuilding[]
  housekeepingTasks HousekeepingTask[]
  maintenanceOrders MaintenanceWorkOrder[]
  dayCloses         PropertyDayClose[]
  experienceProducts     ExperienceProduct[]
  experienceReservations ExperienceReservation[]
  membershipScopes       MembershipPropertyScope[]
  mealPackages           MealPackage[]
  diningCapacities       DiningCapacity[]
  mealReservations       MealReservation[]
  mealInquiries          MealInquiry[]
  serviceRequests        ServiceRequest[]
  fleetRates             AssetFleetRate[]
  rentalReservations     RentalReservation[]
  driverJobs             DriverJob[]
  serviceLocations       ServiceLocation[]
  serviceOfferings       ServiceOffering[]
  tableSessions          TableSession[]
  serviceOrders          ServiceOrder[]
  guestServiceRequests   GuestServiceRequest[]
  serviceOfferingRatings ServiceOfferingRating[]
  guestQrFeedbacks       GuestQrFeedback[]

  @@index([organizationId, isActive])
  @@index([organizationId, assetKind])
  @@index([placeId])
  @@map("partner_assets")
}

/** Sellable room / unit under a stay PartnerAsset (hotel | homestay | farmstay). */
model AssetRoomProduct {
  id                 String    @id @default(cuid())
  assetId            String    @map("asset_id")
  /** Internal / ops name — used in rates, inventory, and matching. */
  name               String
  /** Optional customer-facing label for proposals; falls back to name. */
  customerFacingName String?   @map("customer_facing_name")
  roomTypeKey        String?   @map("room_type_key")
  maxOccupancy       Int       @default(2) @map("max_occupancy")
  bedConfig          String?   @map("bed_config")
  baseQuantity       Int       @default(1) @map("base_quantity")
  rateHint           Decimal?  @map("rate_hint") @db.Decimal(14, 2)
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  asset       PartnerAsset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  allotments  AssetAllotment[]
  allocations InventoryAllocation[]
  units       AssetRoomUnit[]
  ratePlans   AssetRatePlan[]
  stayReservations StayReservation[]
  hotelRates  SupplierHotelRate[]

  @@index([assetId, isActive])
  @@map("asset_room_products")
}

/** Physical or labeled unit under a room product (e.g. "101"). */
model AssetRoomUnit {
  id            String    @id @default(cuid())
  roomProductId String    @map("room_product_id")
  buildingId    String?   @map("building_id")
  floorId       String?   @map("floor_id")
  name          String
  floor         String?
  /** vacant_clean | vacant_dirty | occupied | ooo | inspected | dnd */
  status        String    @default("vacant_clean")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  roomProduct      AssetRoomProduct  @relation(fields: [roomProductId], references: [id], onDelete: Cascade)
  building         AssetBuilding?    @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  floorRef         AssetFloor?       @relation(fields: [floorId], references: [id], onDelete: SetNull)
  stayReservations StayReservation[]
  housekeepingTasks HousekeepingTask[]
  maintenanceOrders MaintenanceWorkOrder[]

  @@index([roomProductId, isActive])
  @@index([roomProductId, status])
  @@index([buildingId])
  @@index([floorId])
  @@map("asset_room_units")
}

/** Thin BAR / seasonal rate on a room product. */
model AssetRatePlan {
  id            String    @id @default(cuid())
  roomProductId String    @map("room_product_id")
  name          String
  amount        Decimal   @db.Decimal(14, 2)
  currency      String    @default("INR") @db.Char(3)
  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  isActive      Boolean   @default(true) @map("is_active")
  /** ROOM_ONLY | BREAKFAST | HALF_BOARD | FULL_BOARD | … */
  mealPlan      String?   @map("meal_plan")
  refundable    Boolean   @default(true)
  minStayNights Int?      @map("min_stay_nights")
  maxStayNights Int?      @map("max_stay_nights")
  closedToArrival   Boolean @default(false) @map("closed_to_arrival")
  closedToDeparture Boolean @default(false) @map("closed_to_departure")
  extraAdultAmount  Decimal? @map("extra_adult_amount") @db.Decimal(14, 2)
  childWithBedAmount Decimal? @map("child_with_bed_amount") @db.Decimal(14, 2)
  childWithoutBedAmount Decimal? @map("child_without_bed_amount") @db.Decimal(14, 2)
  restrictionsJson Json?  @map("restrictions_json")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  roomProduct AssetRoomProduct @relation(fields: [roomProductId], references: [id], onDelete: Cascade)

  @@index([roomProductId, isActive])
  @@index([roomProductId, startDate, endDate])
  @@map("asset_rate_plans")
}

/**
 * Partner-facing stay record (inbound agency + manual / walk-in).
 * Consumes allotment via InventoryAllocation when confirmed.
 */
model StayReservation {
  id                     String    @id @default(cuid())
  assetId                String    @map("asset_id")
  roomProductId          String?   @map("room_product_id")
  roomUnitId             String?   @map("room_unit_id")
  checkIn                DateTime  @map("check_in") @db.Date
  checkOut               DateTime  @map("check_out") @db.Date
  /** inquiry | tentative | held | confirmed | checked_in | checked_out | cancelled | no_show */
  status                 String    @default("confirmed")
  guestName              String    @map("guest_name")
  guestPhone             String?   @map("guest_phone")
  guestEmail             String?   @map("guest_email")
  partyId                String?   @map("party_id")
  /** agency_inbound | manual | walk_in | phone | website | corporate | network */
  source                 String    @default("manual")
  bookingComponentId     String?   @map("booking_component_id")
  serviceRequestId       String?   @map("service_request_id")
  inventoryAllocationId  String?   @map("inventory_allocation_id")
  rateAmount             Decimal?  @map("rate_amount") @db.Decimal(14, 2)
  /** Soft-folio payments received (A-STAY-02); outstanding = folio charges − amountPaid. */
  amountPaid             Decimal   @default(0) @map("amount_paid") @db.Decimal(14, 2)
  currency               String    @default("INR") @db.Char(3)
  mealPlan               String?   @map("meal_plan")
  adults                 Int       @default(1)
  children               Int       @default(0)
  rateSnapshotJson       Json?     @map("rate_snapshot_json")
  policySnapshotJson     Json?     @map("policy_snapshot_json")
  notes                  String?   @db.Text
  confirmationRef        String?   @map("confirmation_ref")
  /** Append-only log of unit reassignments — [{ from, to, at, by, note }]. */
  assignmentHistoryJson  Json?     @map("assignment_history_json")
  /** entire_home | private_room — homestay/farmstay inventory mode. */
  inventoryMode          String?   @map("inventory_mode")
  hostPresent            Boolean?  @map("host_present")
  houseRulesAckAt        DateTime? @map("house_rules_ack_at")
  mealCutoffHours        Int?      @map("meal_cutoff_hours")
  flexibleCheckIn        Boolean?  @map("flexible_check_in")
  /** 4-digit PIN shown at check-in for QR room-service orders (Guest Services). */
  roomServicePin         String?   @map("room_service_pin") @db.VarChar(8)
  createdBy              String?   @map("created_by")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  asset               PartnerAsset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  roomProduct         AssetRoomProduct?    @relation(fields: [roomProductId], references: [id], onDelete: SetNull)
  roomUnit            AssetRoomUnit?       @relation(fields: [roomUnitId], references: [id], onDelete: SetNull)
  bookingComponent    BookingComponent?    @relation(fields: [bookingComponentId], references: [id], onDelete: SetNull)
  serviceRequest      ServiceRequest?      @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  inventoryAllocation InventoryAllocation? @relation(fields: [inventoryAllocationId], references: [id], onDelete: SetNull)
  folioCharges        FolioCharge[]
  serviceOrders       ServiceOrder[]

  @@index([assetId, status])
  @@index([assetId, checkIn, checkOut])
  @@index([bookingComponentId])
  @@index([serviceRequestId])
  @@index([roomUnitId])
  @@map("stay_reservations")
}

/** Nightly stock window for a room product. */
model AssetAllotment {
  id             String   @id @default(cuid())
  roomProductId  String   @map("room_product_id")
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  availableCount Int      @map("available_count")
  stopSell       Boolean  @default(false) @map("stop_sell")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  roomProduct AssetRoomProduct @relation(fields: [roomProductId], references: [id], onDelete: Cascade)

  @@index([roomProductId, startDate, endDate])
  @@map("asset_allotments")
}

/** Vehicle unit under a car_rental / vehicle PartnerAsset. */
model AssetFleetUnit {
  id             String    @id @default(cuid())
  assetId        String    @map("asset_id")
  name           String
  plateNumber    String?   @map("plate_number")
  seats          Int?
  vehicleTypeKey String?   @map("vehicle_type_key")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  asset          PartnerAsset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  calendarBlocks AssetCalendarBlock[]
  allocations    InventoryAllocation[]
  rentals        RentalReservation[]
  driverJobs     DriverJob[]

  @@index([assetId, isActive])
  @@map("asset_fleet_units")
}

/** Daily rental rate + deposit for a car_rental PartnerAsset (Mobility OS 1.0). */
model AssetFleetRate {
  id            String    @id @default(cuid())
  assetId       String    @map("asset_id")
  name          String
  amountPerDay  Decimal   @map("amount_per_day") @db.Decimal(14, 2)
  depositAmount Decimal   @default(0) @map("deposit_amount") @db.Decimal(14, 2)
  currency      String    @default("INR") @db.Char(3)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  asset        PartnerAsset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  reservations RentalReservation[]

  @@index([assetId, isActive])
  @@map("asset_fleet_rates")
}

/**
 * Car rental reservation (Mobility OS 1.0).
 * Lifecycle: held → confirmed → checked_out → returned | cancelled | no_show
 */
model RentalReservation {
  id                    String    @id @default(cuid())
  assetId               String    @map("asset_id")
  fleetUnitId           String    @map("fleet_unit_id")
  fleetRateId           String?   @map("fleet_rate_id")
  inventoryAllocationId String?   @map("inventory_allocation_id")
  inventoryHoldId       String?   @map("inventory_hold_id")
  partyId               String?   @map("party_id")
  guestName             String    @map("guest_name")
  guestPhone            String?   @map("guest_phone")
  startAt               DateTime  @map("start_at")
  endAt                 DateTime  @map("end_at")
  /** held | confirmed | checked_out | returned | cancelled | no_show */
  status                String    @default("held")
  rateAmount            Decimal?  @map("rate_amount") @db.Decimal(14, 2)
  depositAmount         Decimal   @default(0) @map("deposit_amount") @db.Decimal(14, 2)
  depositPaid           Decimal   @default(0) @map("deposit_paid") @db.Decimal(14, 2)
  amountPaid            Decimal   @default(0) @map("amount_paid") @db.Decimal(14, 2)
  currency              String    @default("INR") @db.Char(3)
  checkoutChecklistJson Json?     @map("checkout_checklist_json")
  returnChecklistJson   Json?     @map("return_checklist_json")
  damageNote            String?   @map("damage_note") @db.Text
  notes                 String?   @db.Text
  rateSnapshotJson      Json?     @map("rate_snapshot_json")
  createdBy             String?   @map("created_by")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  asset               PartnerAsset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fleetUnit           AssetFleetUnit       @relation(fields: [fleetUnitId], references: [id], onDelete: Cascade)
  fleetRate           AssetFleetRate?      @relation(fields: [fleetRateId], references: [id], onDelete: SetNull)
  inventoryAllocation InventoryAllocation? @relation(fields: [inventoryAllocationId], references: [id], onDelete: SetNull)
  inventoryHold       InventoryHold?       @relation(fields: [inventoryHoldId], references: [id], onDelete: SetNull)
  party               Party?               @relation(fields: [partyId], references: [id], onDelete: SetNull)
  folioCharges        FolioCharge[]

  @@index([assetId, status])
  @@index([fleetUnitId, startAt, endAt])
  @@index([partyId])
  @@map("rental_reservations")
}

/**
 * Driver duty / transfer job (Mobility Driver OS 1.0).
 * Lifecycle: offered → assigned → en_route → completed | cancelled | no_show
 */
model DriverJob {
  id                    String    @id @default(cuid())
  assetId               String    @map("asset_id")
  inventoryAllocationId String?   @map("inventory_allocation_id")
  inventoryHoldId       String?   @map("inventory_hold_id")
  serviceRequestId      String?   @map("service_request_id")
  /** Agency transfer booking that spawned this job (movement drag-assign sync). */
  bookingComponentId    String?   @map("booking_component_id")
  /** Fleet plate assigned from agency ops (when partner asset has units). */
  fleetUnitId           String?   @map("fleet_unit_id")
  partyId               String?   @map("party_id")
  guestName             String    @map("guest_name")
  guestPhone            String?   @map("guest_phone")
  pickupLocation        String?   @map("pickup_location")
  dropLocation          String?   @map("drop_location")
  startAt               DateTime  @map("start_at")
  endAt                 DateTime  @map("end_at")
  /** offered | assigned | en_route | completed | cancelled | no_show */
  status                String    @default("offered")
  rateAmount            Decimal?  @map("rate_amount") @db.Decimal(14, 2)
  amountPaid            Decimal   @default(0) @map("amount_paid") @db.Decimal(14, 2)
  currency              String    @default("INR") @db.Char(3)
  notes                 String?   @db.Text
  completionNote        String?   @map("completion_note") @db.Text
  createdBy             String?   @map("created_by")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  asset               PartnerAsset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  inventoryAllocation InventoryAllocation? @relation(fields: [inventoryAllocationId], references: [id], onDelete: SetNull)
  inventoryHold       InventoryHold?       @relation(fields: [inventoryHoldId], references: [id], onDelete: SetNull)
  serviceRequest      ServiceRequest?      @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  bookingComponent    BookingComponent?    @relation(fields: [bookingComponentId], references: [id], onDelete: SetNull)
  fleetUnit           AssetFleetUnit?      @relation(fields: [fleetUnitId], references: [id], onDelete: SetNull)
  party               Party?               @relation(fields: [partyId], references: [id], onDelete: SetNull)

  @@index([assetId, status])
  @@index([assetId, startAt, endAt])
  @@index([serviceRequestId])
  @@index([bookingComponentId])
  @@index([fleetUnitId, startAt, endAt])
  @@index([partyId])
  /** One partner job per agency transfer booking (partial unique in migration). */
  @@map("driver_jobs")
}

/** Busy / available / booked intervals for assets or fleet units (also drivers). */
model AssetCalendarBlock {
  id           String   @id @default(cuid())
  assetId      String   @map("asset_id")
  fleetUnitId  String?  @map("fleet_unit_id")
  startAt      DateTime @map("start_at")
  endAt        DateTime @map("end_at")
  /** available | blocked | booked */
  kind         String   @default("blocked")
  allocationId String?  @map("allocation_id")
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  asset      PartnerAsset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fleetUnit  AssetFleetUnit?        @relation(fields: [fleetUnitId], references: [id], onDelete: Cascade)
  allocation InventoryAllocation?   @relation(fields: [allocationId], references: [id], onDelete: SetNull)

  @@index([assetId, startAt, endAt])
  @@index([fleetUnitId, startAt, endAt])
  @@map("asset_calendar_blocks")
}

/** Restaurant meal / package offer with optional capacity. */
model AssetServiceOffer {
  id            String    @id @default(cuid())
  assetId       String    @map("asset_id")
  name          String
  description   String?   @db.Text
  capacity      Int?
  serviceDate   DateTime? @map("service_date") @db.Date
  /** breakfast | lunch | dinner | all_day | custom */
  serviceWindow String?   @map("service_window")
  rateHint      Decimal?  @map("rate_hint") @db.Decimal(14, 2)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  asset PartnerAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, isActive])
  @@index([assetId, serviceDate])
  @@map("asset_service_offers")
}

/**
 * Reservation against stay allotment or fleet/driver calendar.
 * Bound to BookingComponent when confirmed from ops / inbound.
 */
model InventoryAllocation {
  id                 String    @id @default(cuid())
  assetId            String    @map("asset_id")
  roomProductId      String?   @map("room_product_id")
  fleetUnitId        String?   @map("fleet_unit_id")
  bookingComponentId String?   @map("booking_component_id")
  checkIn            DateTime? @map("check_in") @db.Date
  checkOut           DateTime? @map("check_out") @db.Date
  startAt            DateTime? @map("start_at")
  endAt              DateTime? @map("end_at")
  quantity           Int       @default(1)
  /** hold | confirmed | released */
  status             String    @default("hold")
  notes              String?   @db.Text
  createdBy          String?   @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  asset            PartnerAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  roomProduct      AssetRoomProduct? @relation(fields: [roomProductId], references: [id], onDelete: SetNull)
  fleetUnit        AssetFleetUnit?   @relation(fields: [fleetUnitId], references: [id], onDelete: SetNull)
  bookingComponent BookingComponent? @relation(fields: [bookingComponentId], references: [id], onDelete: SetNull)
  calendarBlocks     AssetCalendarBlock[]
  stayReservations   StayReservation[]
  rentalReservations RentalReservation[]
  driverJobs         DriverJob[]

  @@index([assetId, status])
  @@index([roomProductId, checkIn, checkOut])
  @@index([fleetUnitId, startAt, endAt])
  @@index([bookingComponentId])
  @@map("inventory_allocations")
}

model OrgRelationship {
  id                 String   @id @default(cuid())
  fromOrganizationId String   @map("from_organization_id")
  toOrganizationId   String   @map("to_organization_id")
  status             String   @default("following") // following | preferred | contracted | blocked
  notes              String?  @db.Text
  createdBy          String?  @map("created_by")
  updatedBy          String?  @map("updated_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  fromOrganization Organization @relation("OrgRelationshipFrom", fields: [fromOrganizationId], references: [id], onDelete: Cascade)
  toOrganization   Organization @relation("OrgRelationshipTo", fields: [toOrganizationId], references: [id], onDelete: Cascade)
  negotiatedRates  NegotiatedRate[]

  @@unique([fromOrganizationId, toOrganizationId])
  @@index([toOrganizationId, status])
  @@index([fromOrganizationId, status])
  @@map("org_relationships")
}

model OrganizationMembership {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  userId         String    @map("user_id")
  isOwner        Boolean   @default(false) @map("is_owner")
  isActive       Boolean   @default(true) @map("is_active")
  /** Bumped on role/membership change to invalidate stale access tokens. */
  authVersion    Int       @default(0) @map("auth_version")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization      @relation(fields: [organizationId], references: [id])
  user         User              @relation(fields: [userId], references: [id])
  roles        MembershipRole[]
  propertyScopes MembershipPropertyScope[]

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_memberships")
}

model Role {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  key            String
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id])
  permissions  RolePermission[]
  memberships  MembershipRole[]

  @@unique([organizationId, key])
  @@map("roles")
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  description String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model MembershipRole {
  membershipId String @map("membership_id")
  roleId       String @map("role_id")

  membership OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role       Role                   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([membershipId, roleId])
  @@map("membership_roles")
}

/**
 * Property/branch scope assignment (RBAC Integrity 1.0 / P1-3). Links a
 * membership to the PartnerAsset(s) it is scoped to. A membership with no rows
 * is treated as org-wide (all properties) for backward compatibility; once any
 * assignment exists, property-scoped permissions are limited to those assets.
 */
model MembershipPropertyScope {
  membershipId   String   @map("membership_id")
  partnerAssetId String   @map("partner_asset_id")
  createdAt      DateTime @default(now()) @map("created_at")

  membership   OrganizationMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  partnerAsset PartnerAsset           @relation(fields: [partnerAssetId], references: [id], onDelete: Cascade)

  @@id([membershipId, partnerAssetId])
  @@index([partnerAssetId])
  @@map("membership_property_scopes")
}

/**
 * Member invitation (P2 admin maturity). A tokenised invite to join an existing
 * organization with a preset role set. Mirrors the SupplierInvite token pattern
 * (hashed token, expiry, status). Accepting creates the membership (and the User
 * with a chosen password when the invitee has no account yet).
 */
model MemberInvite {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  email          String
  fullName       String?   @map("full_name")
  /** Role ids to assign on accept (snapshot at invite time). */
  roleIdsJson    Json      @map("role_ids_json")
  tokenHash      String    @unique @map("token_hash")
  status         String    @default("pending") // pending | accepted | revoked | expired
  invitedBy      String?   @map("invited_by")
  acceptedUserId String?   @map("accepted_user_id")
  acceptedAt     DateTime? @map("accepted_at")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([email])
  @@map("member_invites")
}

model RefreshToken {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  /** Selected organization for this session (org switcher). */
  organizationId String?   @map("organization_id")
  tokenHash      String    @map("token_hash")
  expiresAt      DateTime  @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ─── Platform ─────────────────────────────────────────────────────────

model AuditEvent {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id")
  metadataJson   Json?    @map("metadata_json")
  correlationId  String?  @map("correlation_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  actor        User?         @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_events")
}

model OutboxEvent {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  eventType      String    @map("event_type")
  payloadJson    Json      @map("payload_json")
  correlationId  String?   @map("correlation_id")
  status         String    @default("pending") // pending | processing | completed | failed
  attempts       Int       @default(0)
  availableAt    DateTime  @default(now()) @map("available_at")
  processedAt    DateTime? @map("processed_at")
  lastError      String?   @map("last_error") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([status, availableAt])
  @@index([organizationId])
  @@map("outbox_events")
}

model Document {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  entityType     String    @map("entity_type")
  entityId       String    @map("entity_id")
  name           String
  /** proposal | quotation | invoice | voucher | contract | … */
  documentType   String    @default("other") @map("document_type")
  version        Int       @default(1)
  mimeType       String    @map("mime_type")
  sizeBytes      Int       @map("size_bytes")
  storageKey     String    @map("storage_key")
  /** local | drive — Drive-backed when Google file storage is enabled. */
  storageProvider String   @default("local") @map("storage_provider")
  driveFileId    String?   @map("drive_file_id")
  driveWebViewLink String? @map("drive_web_view_link") @db.Text
  visibility     String    @default("internal") // internal | customer | restricted
  status         String    @default("active") // draft | active | superseded | archived
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, entityType, entityId])
  @@index([organizationId, documentType])
  @@map("documents")
}

model Notification {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  userId         String    @map("user_id")
  channel        String    @default("in_app") // in_app | email | both
  title          String
  body           String    @db.Text
  linkPath       String?   @map("link_path")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, userId, readAt])
  @@map("notifications")
}

model Task {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  title          String
  description    String?   @db.Text
  status         String    @default("open") // open | done | cancelled
  priority       String    @default("normal") // low | normal | high
  dueAt          DateTime? @map("due_at")
  assigneeId     String?   @map("assignee_id")
  entityType     String?   @map("entity_type")
  entityId       String?   @map("entity_id")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  assignee     User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])

  @@index([organizationId, status, dueAt])
  @@index([organizationId, entityType, entityId])
  @@map("tasks")
}

// ─── CRM: Parties ─────────────────────────────────────────────────────

model Party {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  type           String // individual | organization
  displayName    String    @map("display_name")
  email          String?
  phone          String?
  taxId          String?   @map("tax_id")
  businessType   String?   @map("business_type") // corporate | travel_agency | reseller | supplier | dmc | hotel | transport | activity
  creditLimit    Decimal?  @map("credit_limit") @db.Decimal(14, 2)
  paymentTerms   String?   @map("payment_terms")
  notes          String?   @db.Text
  metadataJson   Json?     @map("metadata_json")
  /** Consent — WhatsApp Cloud API template sends require an explicit opt-in. */
  whatsappOptIn  Boolean   @default(true) @map("whatsapp_opt_in")
  emailOptIn     Boolean   @default(true) @map("email_opt_in")
  marketingOptIn Boolean   @default(false) @map("marketing_opt_in")
  optedOutAt     DateTime? @map("opted_out_at")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  contacts     PartyContact[]
  addresses    Address[]
  leads        Lead[]
  inquiries    Inquiry[]
  trips        Trip[]
  contextRoles  PartyContextRole[]
  conversations            Conversation[]
  mealReservations         MealReservation[]
  mealInquiries            MealInquiry[]
  experienceReservations   ExperienceReservation[]
  rentalReservations       RentalReservation[]
  driverJobs               DriverJob[]
  interactions             Interaction[]
  engagementConversations  EngagementConversation[]

  @@index([organizationId, type])
  @@index([organizationId, email])
  @@index([organizationId, phone])
  @@map("parties")
}

/** Context role for a party on a business entity (guest, diner, traveller…). */
model PartyContextRole {
  id         String   @id @default(cuid())
  partyId    String   @map("party_id")
  role       String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  createdAt  DateTime @default(now()) @map("created_at")

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId])
  @@index([entityType, entityId])
  @@unique([partyId, role, entityType, entityId])
  @@map("party_context_roles")
}

model PartyContact {
  id        String   @id @default(cuid())
  partyId   String   @map("party_id")
  fullName  String   @map("full_name")
  email     String?
  phone     String?
  title     String?
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId])
  @@map("party_contacts")
}

model Address {
  id        String  @id @default(cuid())
  partyId   String  @map("party_id")
  label     String  @default("primary")
  line1     String
  line2     String?
  city      String?
  state     String?
  postalCode String? @map("postal_code")
  country   String? @db.Char(2)

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId])
  @@map("addresses")
}

// ─── CRM: Leads ───────────────────────────────────────────────────────

model LeadSource {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  key            String
  isActive       Boolean @default(true) @map("is_active")

  organization Organization @relation(fields: [organizationId], references: [id])
  leads        Lead[]

  @@unique([organizationId, key])
  @@map("lead_sources")
}

/** Meta-approved WhatsApp template metadata for outbound template sends (marketing/utility). */
model WhatsAppTemplate {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  name             String
  metaTemplateName String   @map("meta_template_name")
  languageCode     String   @map("language_code")
  bodyPreview      String?  @map("body_preview") @db.Text
  variableCount    Int      @default(0) @map("variable_count")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@map("whatsapp_templates")
}

/** Org-defined extra fields for leads/parties, values stored in each entity's customFieldsJson. */
model CustomFieldDefinition {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  /// lead | party
  entity         String
  key            String
  label          String
  /// text | number | boolean | select
  fieldType      String   @default("text") @map("field_type")
  optionsJson    Json?    @map("options_json")
  required       Boolean  @default(false)
  position       Int      @default(0)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, entity, key])
  @@map("custom_field_definitions")
}

/// Shared place catalog (system + tenant) used as origin, destination, or stop.
model Place {
  id             String    @id @default(cuid())
  organizationId String?   @map("organization_id")
  name           String
  key            String
  /// country | region | state | city | area | landmark | airport | railway_station
  kind           String    @default("city")
  parentId       String?   @map("parent_id")
  country        String    @default("India")
  /// @deprecated Prefer parent chain; kept as display fallback
  region         String?
  domesticOrIntl String    @default("domestic") @map("domestic_or_intl") // domestic | international
  isSystem       Boolean   @default(false) @map("is_system")
  isActive       Boolean   @default(true) @map("is_active")
  /** Rich profile: description, images, hours, duration, maps, suitability, coords… */
  profileJson    Json?     @map("profile_json")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  parent       Place?        @relation("PlaceTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Place[]       @relation("PlaceTree")
  subcategoryLinks PlaceSubcategoryLink[]
  edgesFrom    PlaceEdge[]   @relation("PlaceEdgeFrom")
  edgesTo      PlaceEdge[]   @relation("PlaceEdgeTo")
  contributions PlaceContribution[]
  knowledge    PlaceKnowledge[]
  suppliersNear Supplier[]   @relation("SupplierNearPlace")
  partnerAssets PartnerAsset[] @relation("PartnerAssetPlace")
  transferFaresFrom TransferFare[] @relation("TransferFareFrom")
  transferFaresTo   TransferFare[] @relation("TransferFareTo")
  hotelRates        SupplierHotelRate[]
  activityRates     SupplierActivityRate[]

  @@index([organizationId, isActive])
  @@index([isSystem, isActive])
  @@index([key])
  @@index([parentId])
  @@index([kind, isActive])
  @@map("places")
}

/** Canonical drive/flight/rail leg between two places (platform knowledge). */
model PlaceEdge {
  id              String   @id @default(cuid())
  fromPlaceId     String   @map("from_place_id")
  toPlaceId       String   @map("to_place_id")
  mode            String   @default("drive") // drive | flight | rail | walk
  distanceKm      Float?   @map("distance_km")
  durationMin     Int?     @map("duration_min")
  roadHint        String?  @map("road_hint")
  stopsJson       Json?    @map("stops_json") // recommended stops [{name,hint}]
  isSystem        Boolean  @default(true) @map("is_system")
  organizationId  String?  @map("organization_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  fromPlace Place @relation("PlaceEdgeFrom", fields: [fromPlaceId], references: [id], onDelete: Cascade)
  toPlace   Place @relation("PlaceEdgeTo", fields: [toPlaceId], references: [id], onDelete: Cascade)

  @@unique([fromPlaceId, toPlaceId, mode])
  @@index([toPlaceId])
  @@map("place_edges")
}

/** Community suggest/edit for platform places (moderated). */
model PlaceContribution {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  submittedByUserId String  @map("submitted_by_user_id")
  placeId          String?  @map("place_id") // null = suggest new
  kind             String   @default("create") // create | edit
  status           String   @default("pending") // pending | approved | rejected
  payloadJson      Json     @map("payload_json")
  reviewNote       String?  @map("review_note") @db.Text
  reviewedByUserId String?  @map("reviewed_by_user_id")
  reviewedAt       DateTime? @map("reviewed_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  place Place? @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([organizationId])
  @@map("place_contributions")
}

/** Seasonal / tip overlays for a place (platform knowledge). */
model PlaceKnowledge {
  id        String   @id @default(cuid())
  placeId   String   @map("place_id")
  season    String   @default("all") // all | winter | summer | monsoon | autumn
  kind      String   // weather | packing | tip | safety | season_rating
  title     String?
  body      String   @db.Text
  metaJson  Json?    @map("meta_json")
  isSystem  Boolean  @default(true) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId, season, kind])
  @@map("place_knowledge")
}

model PlaceCategory {
  id             String    @id @default(cuid())
  organizationId String?   @map("organization_id")
  name           String
  key            String
  isSystem       Boolean   @default(false) @map("is_system")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization  Organization?     @relation(fields: [organizationId], references: [id])
  subcategories PlaceSubcategory[]

  @@index([organizationId, isActive])
  @@index([isSystem, isActive])
  @@index([key])
  @@map("place_categories")
}

model PlaceSubcategory {
  id             String    @id @default(cuid())
  categoryId     String    @map("category_id")
  organizationId String?   @map("organization_id")
  name           String
  key            String
  isSystem       Boolean   @default(false) @map("is_system")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  category   PlaceCategory          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  organization Organization?        @relation(fields: [organizationId], references: [id])
  placeLinks PlaceSubcategoryLink[]

  @@index([categoryId])
  @@index([organizationId, isActive])
  @@index([key])
  @@map("place_subcategories")
}

model PlaceSubcategoryLink {
  placeId        String @map("place_id")
  subcategoryId  String @map("subcategory_id")

  place       Place             @relation(fields: [placeId], references: [id], onDelete: Cascade)
  subcategory PlaceSubcategory  @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)

  @@id([placeId, subcategoryId])
  @@map("place_subcategory_links")
}

/// Shared room type catalog (system + tenant) for hotel itinerary items.
model RoomType {
  id             String    @id @default(cuid())
  organizationId String?   @map("organization_id")
  name           String
  key            String
  description    String?
  isSystem       Boolean   @default(false) @map("is_system")
  isActive       Boolean   @default(true) @map("is_active")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId, isActive])
  @@index([isSystem, isActive])
  @@index([key])
  @@map("room_types")
}

/// Shared vehicle type catalog (system + tenant) for transfer itinerary items.
model VehicleType {
  id             String    @id @default(cuid())
  organizationId String?   @map("organization_id")
  name           String
  key            String
  description    String?   @db.Text
  seats          Int?
  /** { imageUrl, imageUrls, suitabilityTags… } */
  profileJson    Json?     @map("profile_json")
  isSystem       Boolean   @default(false) @map("is_system")
  isActive       Boolean   @default(true) @map("is_active")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  transferFares TransferFare[]

  @@index([organizationId, isActive])
  @@index([isSystem, isActive])
  @@index([key])
  @@map("vehicle_types")
}

model Campaign {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  externalId     String? @map("external_id")

  organization Organization @relation(fields: [organizationId], references: [id])
  leads        Lead[]

  @@index([organizationId])
  @@map("campaigns")
}

model Pipeline {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  isDefault      Boolean @default(false) @map("is_default")

  organization Organization    @relation(fields: [organizationId], references: [id])
  stages       PipelineStage[]
  leads        Lead[]

  @@index([organizationId])
  @@map("pipelines")
}

model PipelineStage {
  id         String  @id @default(cuid())
  pipelineId String  @map("pipeline_id")
  name       String
  key        String
  position   Int
  isWon      Boolean @default(false) @map("is_won")
  isLost     Boolean @default(false) @map("is_lost")

  pipeline Pipeline           @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads    Lead[]
  history  LeadStageHistory[]

  @@unique([pipelineId, key])
  @@index([pipelineId, position])
  @@map("pipeline_stages")
}

model Lead {
  id               String    @id @default(cuid())
  organizationId   String    @map("organization_id")
  pipelineId       String    @map("pipeline_id")
  stageId          String    @map("stage_id")
  partyId          String?   @map("party_id")
  sourceId         String?   @map("source_id")
  campaignId       String?   @map("campaign_id")
  ownerId          String?   @map("owner_id")
  title            String
  contactName      String?   @map("contact_name")
  email            String?
  phone            String?
  priority         String    @default("normal")
  score            Int?
  tagsJson         Json?     @map("tags_json")
  followUpAt       DateTime? @map("follow_up_at")
  lostReason       String?   @map("lost_reason")
  externalId       String?   @map("external_id")
  idempotencyKey   String?   @map("idempotency_key")
  /** How this lead's creating interaction arrived (phone, whatsapp, website…). */
  channel          String?
  customFieldsJson Json?     @map("custom_fields_json")
  createdBy        String?   @map("created_by")
  updatedBy        String?   @map("updated_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  organization Organization       @relation(fields: [organizationId], references: [id])
  pipeline     Pipeline           @relation(fields: [pipelineId], references: [id])
  stage        PipelineStage      @relation(fields: [stageId], references: [id])
  party        Party?             @relation(fields: [partyId], references: [id])
  source       LeadSource?        @relation(fields: [sourceId], references: [id])
  campaign     Campaign?          @relation(fields: [campaignId], references: [id])
  owner        User?              @relation("LeadOwner", fields: [ownerId], references: [id])
  activities   Activity[]
  stageHistory LeadStageHistory[]
  inquiries    Inquiry[]
  interactions Interaction[]

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, stageId])
  @@index([organizationId, ownerId])
  @@index([organizationId, email])
  @@index([organizationId, phone])
  @@map("leads")
}

model LeadStageHistory {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  stageId   String   @map("stage_id")
  changedBy String?  @map("changed_by")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  lead  Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stage PipelineStage @relation(fields: [stageId], references: [id])

  @@index([leadId, createdAt])
  @@map("lead_stage_history")
}

model Activity {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  leadId         String?  @map("lead_id")
  inquiryId      String?  @map("inquiry_id")
  tripId         String?  @map("trip_id")
  type           String // note | call | email | status_change | system
  body           String   @db.Text
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([organizationId, leadId])
  @@map("activities")
}

/**
 * Org-scoped Google Workspace / Business connection (CodePoetry platform OAuth app).
 * Refresh tokens encrypted at rest — never paste Meta-style tokens for Google.
 */
model GoogleConnection {
  id                   String    @id @default(cuid())
  organizationId       String    @map("organization_id")
  connectedByUserId    String?   @map("connected_by_user_id")
  googleAccountEmail   String?   @map("google_account_email")
  /** AES-GCM ciphertext of the refresh token. */
  refreshTokenEnc      String    @map("refresh_token_enc") @db.Text
  scopesJson           Json      @map("scopes_json")
  accessTokenEnc       String?   @map("access_token_enc") @db.Text
  tokenExpiry          DateTime? @map("token_expiry")
  /** connected | revoked | error */
  status               String    @default("connected")
  /** Selected GBP location resource names / ids. */
  locationsJson        Json?     @map("locations_json")
  calendarId           String?   @map("calendar_id")
  driveRootFolderId    String?   @map("drive_root_folder_id")
  /** When true, new uploads are also stored in the agency Drive folder. */
  useDriveAsFileStorage Boolean  @default(false) @map("use_drive_as_file_storage")
  syncFollowUpsToCalendar Boolean @default(true) @map("sync_follow_ups_to_calendar")
  lastSyncAt           DateTime? @map("last_sync_at")
  lastError            String?   @map("last_error") @db.Text
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId])
  @@index([status])
  @@map("google_connections")
}

/**
 * Sales engagement thread — one customer, many channels, many travel requests (inquiries).
 * Distinct from commerce `Conversation` (ops/B2B entity chat).
 */
model EngagementConversation {
  id                 String    @id @default(cuid())
  organizationId     String    @map("organization_id")
  partyId            String?   @map("party_id")
  /** open | waiting | closed */
  status             String    @default("open")
  assignedUserId     String?   @map("assigned_user_id")
  subject            String?
  lastInteractionAt  DateTime  @default(now()) @map("last_interaction_at")
  unreadCount        Int       @default(0) @map("unread_count")
  /** Ordered channel hops for journey analytics, e.g. ["facebook","website","whatsapp"]. */
  journeyPathJson    Json?     @map("journey_path_json")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party?       @relation(fields: [partyId], references: [id], onDelete: SetNull)
  interactions Interaction[]
  inquiries    Inquiry[]

  @@index([organizationId, lastInteractionAt], map: "eng_conv_org_last_idx")
  @@index([organizationId, status, lastInteractionAt], map: "eng_conv_org_status_last_idx")
  @@index([organizationId, assignedUserId, lastInteractionAt], map: "eng_conv_org_assignee_last_idx")
  @@index([partyId, status], map: "eng_conv_party_status_idx")
  @@map("engagement_conversations")
}

/**
 * Omnichannel touchpoint — every inbound/outbound contact before or around a travel request.
 * Channel = how they reached us; acquisitionSourceKey = how they first found us (optional).
 */
model Interaction {
  id                     String   @id @default(cuid())
  organizationId         String   @map("organization_id")
  conversationId         String?  @map("conversation_id")
  partyId                String?  @map("party_id")
  leadId                 String?  @map("lead_id")
  inquiryId              String?  @map("inquiry_id")
  /** phone | whatsapp | website | email | walk_in | import | api | facebook | instagram */
  channel                String
  /** LeadSource.key for first-touch discovery when known. */
  acquisitionSourceKey   String?  @map("acquisition_source_key")
  staffUserId            String?  @map("staff_user_id")
  occurredAt             DateTime @default(now()) @map("occurred_at")
  /** pending | created_travel_request | attached_existing | follow_up | spam | no_interest */
  outcome                String   @default("pending")
  unread                 Boolean  @default(true)
  summary                String?  @db.Text
  /** Webhook/CSV dedupe key — unique per organization when set. */
  idempotencyKey         String?  @map("idempotency_key")
  rawPayloadJson         Json?    @map("raw_payload_json")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation EngagementConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  party        Party?                  @relation(fields: [partyId], references: [id], onDelete: SetNull)
  lead         Lead?                   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, occurredAt])
  @@index([organizationId, channel, occurredAt])
  @@index([organizationId, unread, occurredAt])
  @@index([partyId, occurredAt])
  @@index([conversationId, occurredAt])
  @@index([inquiryId])
  @@map("interactions")
}

/** Lightweight automation on engagement conversation events (assign, SLA flag, auto-tag). */
model EngagementAutomationRule {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  /** interaction.ingested | conversation.waiting | conversation.unread_sla */
  trigger        String
  /** channel filter optional */
  channel        String?
  /** JSON action: { assignUserId?, setStatus?, tag? } */
  actionJson     Json     @map("action_json")
  isActive       Boolean  @default(true) @map("is_active")
  position       Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive, position], map: "eng_auto_org_active_pos_idx")
  @@map("engagement_automation_rules")
}

// ─── Inquiries ────────────────────────────────────────────────────────

model Inquiry {
  id                 String    @id @default(cuid())
  organizationId     String    @map("organization_id")
  inquiryNumber      String    @map("inquiry_number")
  partyId            String?   @map("party_id")
  leadId             String?   @map("lead_id")
  /** Sales EngagementConversation this travel request hangs off (many TRs per conversation). */
  engagementConversationId String? @map("engagement_conversation_id")
  ownerId            String?   @map("owner_id")
  status             String    @default("open") // open | qualified | converted | lost | closed
  travelType         String?   @map("travel_type")
  domesticOrIntl     String?   @map("domestic_or_intl") // domestic | international
  origin             String?
  originPlaceId      String?   @map("origin_place_id")
  destinationsJson   Json?     @map("destinations_json")
  stopsJson          Json?     @map("stops_json")
  dateFlexible       Boolean   @default(false) @map("date_flexible")
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  nights             Int?
  adults             Int       @default(1)
  children           Int       @default(0)
  infants            Int       @default(0)
  roomRequirements   String?   @map("room_requirements") @db.Text
  budgetAmount       Decimal?  @map("budget_amount") @db.Decimal(14, 2)
  budgetCurrency     String?   @map("budget_currency") @db.Char(3)
  hotelCategory      String?   @map("hotel_category")
  meals              String?
  transportPref      String?   @map("transport_pref")
  flightsRequired    Boolean   @default(false) @map("flights_required")
  visaAssistance     Boolean   @default(false) @map("visa_assistance")
  insurance          Boolean   @default(false)
  interestsJson      Json?     @map("interests_json")
  specialRequirements String?  @map("special_requirements") @db.Text
  internalNotes      String?   @map("internal_notes") @db.Text
  expectedCloseAt    DateTime? @map("expected_close_at")
  missingFieldsJson  Json?     @map("missing_fields_json")
  createdBy          String?   @map("created_by")
  updatedBy          String?   @map("updated_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  organization             Organization             @relation(fields: [organizationId], references: [id])
  party                    Party?                   @relation(fields: [partyId], references: [id])
  lead                     Lead?                    @relation(fields: [leadId], references: [id])
  engagementConversation   EngagementConversation?  @relation(fields: [engagementConversationId], references: [id], onDelete: SetNull)
  statusHistory InquiryStatusHistory[]
  trips        Trip[]

  @@unique([organizationId, inquiryNumber])
  @@index([organizationId, status])
  @@index([organizationId, ownerId])
  @@index([engagementConversationId])
  @@map("inquiries")
}

model InquiryStatusHistory {
  id        String   @id @default(cuid())
  inquiryId String   @map("inquiry_id")
  status    String
  changedBy String?  @map("changed_by")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, createdAt])
  @@map("inquiry_status_history")
}

// ─── Trips / travellers / itineraries / quotations ────────────────────

model Trip {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  tripNumber     String    @map("trip_number")
  inquiryId      String?   @map("inquiry_id")
  partyId        String?   @map("party_id")
  ownerId        String?   @map("owner_id")
  title          String
  status         String    @default("planning")
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  destinationsJson Json?   @map("destinations_json")
  cancellationReason String? @map("cancellation_reason") @db.Text
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization       @relation(fields: [organizationId], references: [id])
  inquiry      Inquiry?           @relation(fields: [inquiryId], references: [id])
  party        Party?             @relation(fields: [partyId], references: [id])
  travellers   TripTraveller[]
  itineraries  Itinerary[]
  quotations   Quotation[]
  bookings     BookingComponent[]
  payments     TripPayment[]
  readinessItems TripReadinessItem[]
  supplierInvoices SupplierInvoice[]
  feedback     TripFeedback[]
  itineraryShareLinks ItineraryShareLink[]
  serviceRequests ServiceRequest[]
  changeCases  TripChangeCase[]
  cancellationCases CancellationCase[]
  incidents    ServiceIncident[]
  closure      TripClosure?

  @@unique([organizationId, tripNumber])
  @@index([organizationId, status])
  @@map("trips")
}

model Traveller {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  fullName       String    @map("full_name")
  type           String    @default("adult") // adult | child | infant
  dateOfBirth    DateTime? @map("date_of_birth")
  passportNumber String?   @map("passport_number") // sensitive
  passportExpiry DateTime? @map("passport_expiry")
  nationality    String?
  email          String?
  phone          String?
  emergencyContact String? @map("emergency_contact")
  preferencesJson Json?    @map("preferences_json")
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  trips TripTraveller[]

  @@index([organizationId])
  @@map("travellers")
}

model TripTraveller {
  id           String  @id @default(cuid())
  tripId       String  @map("trip_id")
  travellerId  String  @map("traveller_id")
  isLead       Boolean @default(false) @map("is_lead")
  roomAllocation String? @map("room_allocation")

  trip      Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  traveller Traveller @relation(fields: [travellerId], references: [id], onDelete: Cascade)

  @@unique([tripId, travellerId])
  @@map("trip_travellers")
}

model Itinerary {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  tripId         String   @map("trip_id")
  title          String   @default("Main itinerary")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  trip     Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  versions ItineraryVersion[]

  @@index([tripId])
  @@map("itineraries")
}

model ItineraryVersion {
  id           String   @id @default(cuid())
  itineraryId  String   @map("itinerary_id")
  versionNumber Int     @map("version_number")
  label        String?
  status       String   @default("draft") // draft | published | archived
  contentJson  Json     @map("content_json") // days + items structured
  versionLock  Int      @default(1) @map("version_lock")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  shareLinks ItineraryShareLink[]

  @@unique([itineraryId, versionNumber])
  @@map("itinerary_versions")
}

model ItineraryShareLink {
  id                  String    @id @default(cuid())
  organizationId      String    @map("organization_id")
  tripId              String    @map("trip_id")
  itineraryVersionId  String    @map("itinerary_version_id")
  /** Quotation version presented on this share; public accept binds to it when set. */
  quotationVersionId  String?   @map("quotation_version_id")
  token               String    @unique
  /** bcrypt hash of family discussion PIN; null = legacy open thread */
  familyPinHash       String?   @map("family_pin_hash")
  expiresAt           DateTime? @map("expires_at")
  revokedAt           DateTime? @map("revoked_at")
  createdBy           String?   @map("created_by")
  createdAt           DateTime  @default(now()) @map("created_at")

  trip    Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  version ItineraryVersion @relation(fields: [itineraryVersionId], references: [id], onDelete: Cascade)
  participants ProposalParticipant[]
  reactions    ProposalReaction[]
  messages     ProposalMessage[]

  @@index([organizationId, tripId])
  @@index([quotationVersionId])
  @@map("itinerary_share_links")
}

/** Soft-identified family member / co-viewer on a shared proposal. */
model ProposalParticipant {
  id           String   @id @default(cuid())
  shareLinkId  String   @map("share_link_id")
  viewerKey    String   @map("viewer_key")
  displayName  String   @map("display_name")
  relationHint String?  @map("relation_hint")
  lastSeenAt   DateTime @default(now()) @map("last_seen_at")
  createdAt    DateTime @default(now()) @map("created_at")

  shareLink ItineraryShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  reactions ProposalReaction[]
  messages  ProposalMessage[]

  @@unique([shareLinkId, viewerKey])
  @@index([shareLinkId])
  @@map("proposal_participants")
}

model ProposalReaction {
  id            String   @id @default(cuid())
  shareLinkId   String   @map("share_link_id")
  participantId String   @map("participant_id")
  kind          String   @default("love")
  createdAt     DateTime @default(now()) @map("created_at")

  shareLink   ItineraryShareLink  @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  participant ProposalParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([shareLinkId, participantId, kind])
  @@index([shareLinkId])
  @@map("proposal_reactions")
}

model ProposalMessage {
  id            String   @id @default(cuid())
  shareLinkId   String   @map("share_link_id")
  participantId String?  @map("participant_id")
  authorRole    String   @map("author_role") // family | agency
  authorName    String   @map("author_name")
  kind          String   @default("comment") // comment | question | answer
  body          String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  shareLink   ItineraryShareLink   @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  participant ProposalParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)

  @@index([shareLinkId, createdAt])
  @@map("proposal_messages")
}

model ItineraryBlock {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  itemType       String   @map("item_type") // hotel | transfer | flight | activity | meal | free_time | note | package_day | package
  /** Day/item skeleton; may include catalogPlaceId refs for hydrate-on-apply. */
  contentJson    Json     @map("content_json")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, itemType])
  @@map("itinerary_blocks")
}

model Quotation {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  tripId         String   @map("trip_id")
  quoteNumber    String   @map("quote_number")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  trip     Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  versions QuotationVersion[]

  @@unique([organizationId, quoteNumber])
  @@index([tripId])
  @@map("quotations")
}

model QuotationVersion {
  id              String    @id @default(cuid())
  quotationId     String    @map("quotation_id")
  versionNumber   Int       @map("version_number")
  label           String?
  status          String    @default("draft") // draft | pending_approval | approved | sent | accepted | rejected | expired
  currency        String    @default("INR") @db.Char(3)
  validUntil      DateTime? @map("valid_until")
  exchangeRatesJson Json?   @map("exchange_rates_json")
  itemsJson       Json      @map("items_json")
  inclusions      String?   @db.Text
  exclusions      String?   @db.Text
  terms           String?   @db.Text
  costTotal       Decimal   @default(0) @map("cost_total") @db.Decimal(14, 2)
  sellTotal       Decimal   @default(0) @map("sell_total") @db.Decimal(14, 2)
  taxTotal        Decimal   @default(0) @map("tax_total") @db.Decimal(14, 2)
  discountTotal   Decimal   @default(0) @map("discount_total") @db.Decimal(14, 2)
  marginAmount    Decimal   @default(0) @map("margin_amount") @db.Decimal(14, 2)
  marginPercent   Decimal   @default(0) @map("margin_percent") @db.Decimal(8, 4)
  pdfDocumentId   String?   @map("pdf_document_id")
  versionLock     Int       @default(1) @map("version_lock")
  acceptedAt      DateTime? @map("accepted_at")
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@unique([quotationId, versionNumber])
  @@map("quotation_versions")
}

model QuoteTemplate {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  contentJson    Json     @map("content_json")
  /** active | superseded */
  status         String   @default("active")
  versionNumber  Int      @default(1) @map("version_number")
  /** Prior template row this version supersedes. */
  supersedesId   String?  @map("supersedes_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization   @relation(fields: [organizationId], references: [id])
  supersedes   QuoteTemplate? @relation("QuoteTemplateVersionChain", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy QuoteTemplate[] @relation("QuoteTemplateVersionChain")

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([supersedesId])
  @@map("quote_templates")
}

// ─── Operations & finance ─────────────────────────────────────────────

model Supplier {
  id                   String    @id @default(cuid())
  organizationId       String    @map("organization_id")
  name                 String
  /** hotel | homestay | farmstay | car_rental | driver | restaurant | activity | guide | dmc | other (+ legacy) */
  type                 String    @default("other")
  email                String?
  phone                String?
  notes                String?   @db.Text
  linkedOrganizationId String?   @map("linked_organization_id")
  /** Preferred Stage B link: specific partner property / vehicle / driver. */
  linkedAssetId        String?   @map("linked_asset_id")
  /** Nearest city / area place for discovery. */
  placeId              String?   @map("place_id")
  /** { imageUrl, imageUrls, amenities, roomHints, vehicleHints, capacityHint… } */
  profileJson          Json?     @map("profile_json")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  organization       Organization  @relation(fields: [organizationId], references: [id])
  linkedOrganization Organization? @relation("SupplierLinkedOrg", fields: [linkedOrganizationId], references: [id])
  linkedAsset        PartnerAsset? @relation("SupplierLinkedAsset", fields: [linkedAssetId], references: [id], onDelete: SetNull)
  place              Place?        @relation("SupplierNearPlace", fields: [placeId], references: [id], onDelete: SetNull)
  bookings           BookingComponent[]
  invoices           SupplierInvoice[]
  invites            SupplierInvite[]
  hotelRates         SupplierHotelRate[]
  activityRates      SupplierActivityRate[]
  transferFares      TransferFare[]
  contracts          SupplierContract[]
  serviceRequests    ServiceRequest[]
  incidents          ServiceIncident[]

  @@index([organizationId, type])
  @@index([linkedOrganizationId])
  @@index([linkedAssetId])
  @@index([placeId])
  @@unique([organizationId, linkedAssetId])
  @@map("suppliers")
}

/** Agency hotel tariff card — cost per room-night for a stay supplier. */
/**
 * Hotel rate card — agency supplier rates or system place+room defaults.
 * System: isSystem=true, organizationId=null, placeId set, supplierId null.
 * Agency: organizationId set; usually supplierId; optional placeId for override of system place defaults.
 */
model SupplierHotelRate {
  id             String    @id @default(cuid())
  organizationId String?   @map("organization_id")
  supplierId     String?   @map("supplier_id")
  /** City/area place for system (or agency override) place-level defaults. */
  placeId        String?   @map("place_id")
  isSystem       Boolean   @default(false) @map("is_system")
  /** Empty/null = default rate for supplier; else matches itinerary details.roomType. */
  roomType       String?   @map("room_type")
  /** Canonical room product on the supplier linked asset (preferred match key). */
  roomProductId  String?   @map("room_product_id")
  /** Owning contract version; null = legacy / system / unversioned agency rate. */
  contractId     String?   @map("contract_id")
  /** Empty/null = any/default meal; else matches itinerary details.mealPlan (EP/CP/MAP/AP…). */
  mealPlan       String?   @map("meal_plan")
  unitCost       Decimal   @map("unit_cost") @db.Decimal(14, 2)
  /** Optional Sat/Sun night cost; weekday nights use unitCost. */
  weekendUnitCost Decimal? @map("weekend_unit_cost") @db.Decimal(14, 2)
  /**
   * Thin occupancy matrix: base adults/children included in unitCost + per-night extras.
   * Shape: { baseAdults, baseChildren?, childAgeMax?, extraAdultPerNight?, childWithBedPerNight?, childWithoutBedPerNight? }
   */
  occupancyPricingJson Json? @map("occupancy_pricing_json")
  currency       String    @default("INR") @db.Char(3)
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  isActive       Boolean   @default(true) @map("is_active")
  /** Version tip number within a supersedes chain (1 = first). */
  versionNumber  Int       @default(1) @map("version_number")
  /** Prior rate row this version supersedes. */
  supersedesId   String?   @map("supersedes_id")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier?         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  place        Place?            @relation(fields: [placeId], references: [id], onDelete: Restrict)
  roomProduct  AssetRoomProduct? @relation(fields: [roomProductId], references: [id], onDelete: SetNull)
  contract     SupplierContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  supersedes   SupplierHotelRate?  @relation("HotelRateVersionChain", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy SupplierHotelRate[] @relation("HotelRateVersionChain")

  @@index([organizationId, supplierId, isActive])
  @@index([organizationId, isActive])
  @@index([isSystem, isActive])
  @@index([placeId, roomType, mealPlan, isActive])
  @@index([roomProductId, isActive])
  @@index([contractId, isActive])
  @@index([supersedesId])
  @@map("supplier_hotel_rates")
}

/**
 * Transfer fare — system catalog, agency override, or supplier-owned chart.
 * unitCost = adult / per-vehicle base cost depending on pricingMode.
 */
model TransferFare {
  id             String    @id @default(cuid())
  organizationId String?   @map("organization_id")
  /** Negotiated corridor on a transport supplier; null = org/system catalog. */
  supplierId     String?   @map("supplier_id")
  isSystem       Boolean   @default(false) @map("is_system")
  fromPlaceId    String    @map("from_place_id")
  toPlaceId      String    @map("to_place_id")
  vehicleTypeId  String    @map("vehicle_type_id")
  /** Adult tariff (per_vehicle full cab OR per_adult seat). */
  unitCost       Decimal   @map("unit_cost") @db.Decimal(14, 2)
  childUnitCost  Decimal?  @map("child_unit_cost") @db.Decimal(14, 2)
  infantUnitCost Decimal?  @map("infant_unit_cost") @db.Decimal(14, 2)
  /** Inclusive child-rate age window for per_adult fares (null = 0–17 default on Match). */
  childAgeMin    Int?      @map("child_age_min")
  childAgeMax    Int?      @map("child_age_max")
  /** per_vehicle | per_adult */
  pricingMode    String    @default("per_vehicle") @map("pricing_mode")
  currency       String    @default("INR") @db.Char(3)
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  isActive       Boolean   @default(true) @map("is_active")
  /** Version tip number within a supersedes chain (1 = first). */
  versionNumber  Int       @default(1) @map("version_number")
  /** Prior fare row this version supersedes. */
  supersedesId   String?   @map("supersedes_id")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier     Supplier?     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  fromPlace    Place         @relation("TransferFareFrom", fields: [fromPlaceId], references: [id], onDelete: Restrict)
  toPlace      Place         @relation("TransferFareTo", fields: [toPlaceId], references: [id], onDelete: Restrict)
  vehicleType  VehicleType   @relation(fields: [vehicleTypeId], references: [id], onDelete: Restrict)
  supersedes   TransferFare?  @relation("TransferFareVersionChain", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy TransferFare[] @relation("TransferFareVersionChain")

  @@index([organizationId, fromPlaceId, toPlaceId, vehicleTypeId, isActive])
  @@index([organizationId, supplierId, isActive])
  @@index([organizationId, isActive])
  @@index([isSystem, isActive])
  @@index([fromPlaceId, toPlaceId, vehicleTypeId, isSystem, isActive])
  @@index([supersedesId])
  @@map("transfer_fares")
}

/**
 * Activity / sightseeing rate card — adult (and optional child) per-person cost.
 * Matched from quote Activity drawer via rates/resolve (type activity → sightseeing).
 */
model SupplierActivityRate {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  supplierId     String?   @map("supplier_id")
  placeId        String?   @map("place_id")
