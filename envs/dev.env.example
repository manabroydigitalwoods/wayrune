# Shared / hosted development environment
APP_ENV=dev
NODE_ENV=development

DATABASE_URL="mysql://travel:CHANGE_ME@dev-db.example:3306/travel_erp"
REDIS_URL="redis://dev-redis.example:6379"

JWT_ACCESS_SECRET="dev-access-secret-change-me-min-32-chars"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-min-32-chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

S3_ENDPOINT="https://s3.example.com"
S3_ACCESS_KEY="CHANGE_ME"
S3_SECRET_KEY="CHANGE_ME"
S3_BUCKET="travel-erp-dev"
S3_REGION="ap-south-1"
FILE_STORAGE=local
UPLOAD_DIR=.data/uploads

API_PORT=3001
API_PUBLIC_URL="https://api-dev.example.com"
WEB_ORIGIN="https://app-dev.example.com"
WEB_PORT=5173

VITE_APP_ENV=dev
VITE_API_BASE_URL="https://api-dev.example.com/api/v1"

LOG_LEVEL=info
LOG_PRETTY=false
LOG_SERVICE_NAME=api
