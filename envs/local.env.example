# Local machine (default for ./dev)
APP_ENV=local
NODE_ENV=development

DATABASE_URL="mysql://root:Root%4012345@127.0.0.1:3306/travel_erp"
REDIS_URL="redis://127.0.0.1:6379"

JWT_ACCESS_SECRET="local-access-secret-change-me-32chars!"
JWT_REFRESH_SECRET="local-refresh-secret-change-me-32chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="travel-erp-local"
S3_REGION="us-east-1"
FILE_STORAGE=local
UPLOAD_DIR=.data/uploads

API_PORT=3001
API_PUBLIC_URL="http://localhost:3001"
WEB_ORIGIN="http://localhost:5173"
WEB_PORT=5173

VITE_APP_ENV=local
VITE_API_BASE_URL="/api/v1"

LOG_LEVEL=info
LOG_PRETTY=true
LOG_SERVICE_NAME=api

# Optional — AI proposal story drafts (server-side only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional — Routes + Places (New) for transfer distances when PlaceEdge is missing.
# Enable in Google Cloud: Routes API, Places API (New). Server-side only.
# Results are cached in PlaceEdge; omit to use seeded edges / manual duration only.
GOOGLE_MAPS_API_KEY=

# Optional — Platform SSO (Google) + Connect Google (Drive / Business Profile / Calendar).
# These are CodePoetry platform credentials (not per-agency). When set, all orgs can use
# Sign in with Google on the login page. Add more providers later the same way (env-level).
# Create an OAuth Web client in Google Cloud Console and set redirect URIs:
#   {API_PUBLIC_URL}/api/v1/auth/oauth/google/callback
#   {API_PUBLIC_URL}/api/v1/integrations/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_BASE="http://localhost:3001"

# Digital Presence — local platform hosts (browsers resolve *.localhost → 127.0.0.1)
# Primary:  http://10001.codepoetry.localhost:5173
# Other:    http://{slug}.10001.codepoetry.localhost:5173
# Live/prod: SITE_BASE_DOMAIN=codepoetry.app (+ DNS + TLS edge)
SITE_BASE_DOMAIN=codepoetry.localhost

# Optional — PostHog Session Replay (named pilot only; never demo-as-proof)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional — SMTP for worker email delivery (notification.email / quote.email).
# Omit SMTP_HOST to skip send (structured log only; outbox still completes).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Wayrune <noreply@localhost>"

# Optional — Guest Services online pay (Razorpay). Omit for mock pay in local.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Guest check e-invoice adapter: noop | demo | nic
# For nic: set EINVOICE_GSP_URL + EINVOICE_GSP_API_KEY (fail-closed without them).
EINVOICE_PROVIDER=demo
# EINVOICE_GSP_URL=
# EINVOICE_GSP_API_KEY=
