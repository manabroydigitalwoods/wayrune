# Production — never commit real secrets
APP_ENV=prod
NODE_ENV=production

DATABASE_URL="mysql://travel:CHANGE_ME@prod-db.example:3306/travel_erp"
REDIS_URL="redis://prod-redis.example:6379"

JWT_ACCESS_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET_32+"
JWT_REFRESH_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET_32+"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

S3_ENDPOINT="https://s3.ap-south-1.amazonaws.com"
S3_ACCESS_KEY="CHANGE_ME"
S3_SECRET_KEY="CHANGE_ME"
S3_BUCKET="travel-erp-prod"
S3_REGION="ap-south-1"
FILE_STORAGE=local
UPLOAD_DIR=.data/uploads

API_PORT=3001
API_PUBLIC_URL="https://api.example.com"
WEB_ORIGIN="https://app.example.com"
WEB_PORT=5173

VITE_APP_ENV=prod
VITE_API_BASE_URL="https://api.example.com/api/v1"

LOG_LEVEL=info
LOG_PRETTY=false
LOG_SERVICE_NAME=api
